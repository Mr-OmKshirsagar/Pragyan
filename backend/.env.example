# ─── Server ────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# NODE_ENV=production   ← uncomment for production

# ─── Database (MongoDB + Prisma) ───────────────────────
# Atlas (cloud / production):
DATABASE_URL="mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/Pragyan?retryWrites=true&w=majority"
# Local (optional development fallback):
# DATABASE_URL="mongodb://localhost:27018/Pragyan?directConnection=true"

# ─── JWT ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change_me_in_production_use_64_char_random_string"
JWT_EXPIRY="7d"
JWT_REFRESH_SECRET="change_me_different_64_char_random_string"
JWT_REFRESH_EXPIRY="30d"

# ─── CORS ──────────────────────────────────────────────
# Local:
FRONTEND_URL="http://localhost:5173"
CORS_ORIGINS="http://localhost:5173"
# Production (comma-separate multiple origins):
# FRONTEND_URL="https://your-app.vercel.app"
RAPID_API_KEY=d1e01739e1mshe481b9e923b8572p116d36jsnc629226ff942

# ─── Bcrypt ────────────────────────────────────────────
BCRYPT_ROUNDS=10
# Increase to 12 in production for stronger hashing

# ─── RapidAPI ──────────────────────────────────────────
RAPID_API_KEY=d1e01739e1mshe481b9e923b8572p116d36jsnc629226ff942

# ─── API Base ──────────────────────────────────────────
API_BASE_URL="http://localhost:5000"
# API_BASE_URL="https://your-backend.onrender.com"   ← production

# ─── AI Provider ──────────────────────────────────────
# Supported providers: gemini, local
AI_PROVIDER=gemini
# Google Gemini API key
GEMINI_API_KEY=AIzaSyDNOZao7XxY53ATGARvKAZKmciuzrGQrvw
# Optional model override
GEMINI_MODEL=gemini-2.5-flash

# ─── Redis Cache (optional) ───────────────────────────
# If set, explanation caching uses Redis instead of in-memory fallback
REDIS_URL=redis://127.0.0.1:6379
